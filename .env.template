# CreativeClaw environment template
# Copy this file to `.env` and fill in only the credentials you need.
# Never commit a real `.env` file.

#
# Default orchestrator model
# Required for the default `openai/gpt-5.4` model in `conf/jsons/system.json`
# Official URL: https://platform.openai.com/api-keys
#
OPENAI_API_KEY=""

#
# Gemini-backed image, vision, and VEO video features
# Required for:
# - ImageGenerationAgent (`nano_banana`)
# - ImageEditingAgent (`nano_banana`)
# - ImageUnderstandingAgent
# - ImageToPromptAgent
# - VideoGenerationAgent (`veo`)
# Official URL: https://aistudio.google.com/app/apikey
#
GOOGLE_API_KEY=""

#
# Optional image generation, image editing, and video generation via Seedream/Seedance
# Official URL: https://console.volcengine.com/ark
#
ARK_API_KEY=""

#
# Optional DeepDataSpace DINO-XSeek grounding
# Official URL: https://cloud.deepdataspace.com/
#
DDS_API_KEY=""

#
# Optional SearchAgent image search
# Official URL: https://serper.dev/
#
SERPER_API_KEY=""

#
# Optional built-in `web_search` tool
# Official URL: https://api.search.brave.com/app/keys
#
BRAVE_API_KEY=""

#
# Optional Doc2X v3 PDF-to-Markdown conversion through pdfdeal
# Official URL: https://doc2x.noedgeai.com/
#
DOC2X_API_KEY=""

#
# Telegram channel
# Official URL: https://core.telegram.org/bots/tutorial#obtain-your-bot-token
#
TELEGRAM_BOT_TOKEN=""
TELEGRAM_ALLOW_FROM=""

#
# Feishu channel
# Official URL: https://open.feishu.cn/app
# `FEISHU_ENCRYPT_KEY` and `FEISHU_VERIFICATION_TOKEN` are only needed
# if you enabled the matching security settings in Feishu event subscriptions.
#
FEISHU_APP_ID=""
FEISHU_APP_SECRET=""
FEISHU_ENCRYPT_KEY=""
FEISHU_VERIFICATION_TOKEN=""
FEISHU_ALLOW_FROM=""
