{
  "id": "brief_elements.meeting_notes",
  "type": "brief_element_schema",
  "title": "Meeting Notes",
  "description": "Key design elements for meeting notes, recaps, decision logs, all-hands summaries, and 1:1 notes.",
  "surface": "notes",
  "scenarios": ["meeting_notes", "minutes", "recap", "decision_log", "one_on_one_notes", "会议纪要"],
  "required_fields": ["meeting_type", "audience", "agenda", "key_decisions", "action_items", "owners", "follow_up_date"],
  "optional_fields": ["attendees", "discussion_summary", "risks", "links", "sentiment", "privacy_level"],
  "question_templates": [
    {"field": "meeting_type", "question": "这是什么会议：项目同步、复盘、1:1、全员会、客户会，还是决策会？"},
    {"field": "agenda", "question": "会议议程或讨论主题有哪些？"},
    {"field": "key_decisions", "question": "已经有哪些结论或待确认决策？"},
    {"field": "action_items", "question": "需要追踪哪些行动项、负责人和截止时间？"}
  ],
  "defaults": {
    "platform": "internal docs",
    "density": "medium",
    "recommended_skill": "meeting-notes",
    "recommended_design_system_candidates": ["notion", "linear-app", "default"],
    "output_contract": "structured meeting notes page"
  }
}
