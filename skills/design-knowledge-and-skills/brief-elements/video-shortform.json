{
  "id": "brief_elements.video_shortform",
  "type": "brief_element_schema",
  "title": "Shortform Video",
  "description": "Key design elements for short videos, reels, product clips, launch teasers, and vertical social video briefs.",
  "surface": "video",
  "scenarios": ["video_shortform", "shortform_video", "reel", "product_clip", "launch_teaser", "短视频", "竖屏视频"],
  "required_fields": ["video_goal", "audience", "duration", "platform", "story_beats", "visual_style", "audio_or_voiceover", "call_to_action"],
  "optional_fields": ["aspect_ratio", "captions", "reference_videos", "brand_context", "asset_sources", "export_format"],
  "question_templates": [
    {"field": "video_goal", "question": "短视频目标是什么：获客、发布、教育、活动预热、品牌认知，还是转化？"},
    {"field": "platform", "question": "发布平台是什么：抖音、小红书、Instagram Reels、YouTube Shorts，还是站内视频？"},
    {"field": "duration", "question": "目标时长是多少：5 秒、15 秒、30 秒，还是更长？"},
