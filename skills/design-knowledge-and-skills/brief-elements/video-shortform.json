  "defaults": {
    "platform": "shortform video",
    "density": "medium",
    "aspect_ratio": "9:16",
    "recommended_skill": "video-shortform",
    "recommended_design_system_candidates": ["runwayml", "xiaohongshu", "default"],
    "output_contract": "structured shortform video brief or storyboard",
    "execution_mode": "video_expert"
  }
