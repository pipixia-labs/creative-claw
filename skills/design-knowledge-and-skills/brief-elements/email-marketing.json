{
  "id": "brief_elements.email_marketing",
  "type": "brief_element_schema",
  "title": "Email Marketing",
  "description": "Key design elements for launch emails, newsletters, lifecycle emails, and marketing email templates.",
  "surface": "email",
  "scenarios": ["email_marketing", "email_template", "newsletter", "launch_email", "lifecycle_email", "邮件营销", "邮件模板"],
  "required_fields": ["campaign_goal", "audience_segment", "subject_line_direction", "core_message", "offer_or_cta", "content_sections", "brand_context"],
  "optional_fields": ["personalization", "legal_footer", "preview_text", "mobile_constraints", "utm_needs", "image_policy"],
  "question_templates": [
    {"field": "campaign_goal", "question": "这封邮件的目标是什么：新品发布、召回、促销、教育、活动邀请，还是续费？"},
    {"field": "audience_segment", "question": "收件人是谁：新用户、活跃用户、沉默用户、企业客户，还是潜在客户？"},
    {"field": "offer_or_cta", "question": "主 CTA 是什么：立即体验、预约演示、领取优惠、阅读文章，还是报名活动？"},
    {"field": "brand_context", "question": "是否有品牌语气、颜色、logo 或必须遵守的邮件规范？"}
  ],
  "defaults": {
    "platform": "email",
    "density": "medium",
    "recommended_skill": "email-marketing",
    "recommended_design_system_candidates": ["stripe", "superhuman", "default"],
    "output_contract": "responsive HTML email concept or MJML-ready template"
  }
}
