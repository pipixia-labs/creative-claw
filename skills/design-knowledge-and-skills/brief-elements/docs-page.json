{
  "id": "brief_elements.docs_page",
  "type": "brief_element_schema",
  "title": "Documentation Page",
  "description": "Key design elements for product documentation, developer docs, API guides, and structured knowledge pages.",
  "surface": "docs_page",
  "scenarios": ["docs_page", "documentation", "api_docs", "developer_docs", "knowledge_base", "文档页", "开发者文档"],
  "required_fields": [
    "audience",
    "documentation_goal",
    "information_architecture",
    "primary_topic",
    "navigation_model",
    "code_or_example_needs",
    "search_or_filter_needs",
    "content_density"
  ],
  "optional_fields": [
    "versioning",
    "api_reference",
    "copy_source",
    "brand_context",
    "callouts",
    "empty_states"
  ],
  "question_templates": [
    {
      "field": "audience",
      "question": "这个文档页主要给谁看：开发者、产品用户、内部团队、客户成功，还是新手用户？"
    },
    {
      "field": "documentation_goal",
      "question": "用户看完文档后要完成什么：快速接入、理解概念、排查问题、学习 API，还是配置产品？"
    },
    {
      "field": "information_architecture",
      "question": "需要哪些章节或导航层级？例如概览、快速开始、指南、API、FAQ。"
    },
    {
      "field": "code_or_example_needs",
      "question": "是否需要代码示例、命令行片段、配置样例或流程图？"
    }
  ],
  "defaults": {
    "platform": "desktop web",
    "density": "medium",
    "recommended_skill": "docs-page",
    "recommended_design_system_candidates": ["mintlify", "vercel", "stripe", "default"],
    "output_contract": "standalone responsive HTML documentation page"
  }
}
