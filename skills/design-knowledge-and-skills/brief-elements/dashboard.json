{
  "id": "brief_elements.dashboard",
  "type": "brief_element_schema",
  "title": "Dashboard / Operation Data UI",
  "description": "Key design elements for operational dashboards, analytics consoles, and internal data tools.",
  "surface": "dashboard",
  "scenarios": ["dashboard", "operation_data_ui", "analytics_dashboard", "admin_panel", "bi_console"],
  "required_fields": [
    "business_domain",
    "primary_user",
    "decision_goal",
    "metrics",
    "dimensions",
    "time_range",
    "interaction_requirements",
    "density",
    "platform"
  ],
  "optional_fields": [
    "brand_context",
    "visual_direction",
    "data_freshness",
    "alert_rules",
    "export_requirements",
    "empty_states",
    "permission_model"
  ],
  "question_templates": [
    {
      "field": "business_domain",
      "question": "这个数据 UI 面向什么业务：电商、内容社区、SaaS、广告投放、门店、直播，还是其他？"
    },
    {
      "field": "primary_user",
      "question": "主要使用者是谁：运营专员、运营负责人、管理层、客户成功，还是数据分析师？"
    },
    {
      "field": "decision_goal",
      "question": "用户打开这个看板后，最重要的决策或动作是什么？例如发现异常、复盘活动、调预算、分配任务。"
    },
    {
      "field": "metrics",
      "question": "最重要的 3-5 个指标是什么？例如 GMV、DAU、转化率、留存、订单、客单价、ROI。"
    },
    {
      "field": "dimensions",
      "question": "需要按哪些维度查看或下钻：渠道、地区、商品、活动、用户分层、时间，还是其他？"
    },
    {
      "field": "time_range",
      "question": "默认时间范围是什么：今天、昨天、7 天、30 天、本月，还是自定义？"
    },
    {
      "field": "interaction_requirements",
      "question": "需要哪些交互：筛选、排序、下钻、对比、标记异常、导出，还是只读看板？"
    },
    {
      "field": "density",
      "question": "信息密度更偏高密度工作台，还是面向汇报的轻量看板？"
    }
  ],
  "defaults": {
    "platform": "desktop web",
    "density": "high",
    "recommended_skill": "dashboard",
    "recommended_design_system_candidates": ["linear-app", "vercel", "stripe", "figma", "default"],
    "output_contract": "standalone responsive HTML dashboard"
  }
}
