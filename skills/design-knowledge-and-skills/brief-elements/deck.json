{
  "id": "brief_elements.deck",
  "type": "brief_element_schema",
  "title": "Slide Deck",
  "description": "Key design elements for pitch decks, updates, readouts, workshops, and presentation-style HTML decks.",
  "surface": "deck",
  "scenarios": ["deck", "slide_deck", "pitch_deck", "presentation", "readout"],
  "required_fields": [
    "deck_purpose",
    "audience",
    "slide_count",
    "narrative_arc",
    "source_material",
    "visual_direction",
    "speaker_notes",
    "aspect_ratio"
  ],
  "optional_fields": [
    "brand_context",
    "data_points",
    "image_requirements",
    "export_requirements",
    "animation_requirements",
    "presenter_context"
  ],
  "question_templates": [
    {
      "field": "deck_purpose",
      "question": "这份 deck 的目的是什么：融资、项目汇报、周报、培训、方案提案，还是复盘？"
    },
    {
      "field": "audience",
      "question": "听众是谁？他们最关心什么？"
    },
    {
      "field": "slide_count",
      "question": "大概需要多少页？"
    },
    {
      "field": "narrative_arc",
      "question": "希望按什么叙事展开：问题-方案-证据-行动，还是背景-洞察-计划-风险？"
    },
    {
      "field": "source_material",
      "question": "是否有现成文案、数据、图片或参考资料？"
    },
    {
      "field": "visual_direction",
      "question": "视觉更偏商务克制、杂志编辑、技术产品、活泼培训，还是让系统推荐？"
    },
    {
      "field": "speaker_notes",
      "question": "需要演讲备注吗？"
    }
  ],
  "defaults": {
    "aspect_ratio": "16:9",
    "speaker_notes": false,
    "recommended_skill": "simple-deck",
    "fallback_skill": "guizang-ppt",
    "recommended_design_system_candidates": ["warm-editorial", "stripe", "vercel", "default"],
    "output_contract": "standalone HTML slide deck"
  }
}
