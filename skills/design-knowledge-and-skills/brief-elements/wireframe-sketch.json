{
  "id": "brief_elements.wireframe_sketch",
  "type": "brief_element_schema",
  "title": "Wireframe Sketch",
  "description": "Key design elements for low-fidelity wireframes, layout exploration, early product flows, and UX structure sketches.",
  "surface": "wireframe",
  "scenarios": ["wireframe_sketch", "wireframe", "low_fidelity", "ux_sketch", "lofi_mockup", "线框图", "低保真"],
  "required_fields": [
    "product_context",
    "target_user",
    "primary_flow",
    "screens_or_sections",
    "information_hierarchy",
    "interaction_points",
    "layout_constraints"
  ],
  "optional_fields": [
    "device_context",
    "existing_reference",
    "content_inventory",
    "edge_cases",
    "handoff_notes"
  ],
  "question_templates": [
    {
      "field": "product_context",
      "question": "这个线框图对应什么产品或功能？"
    },
    {
      "field": "primary_flow",
      "question": "用户主要要完成哪条流程？例如注册、下单、创建项目、查看数据、提交审核。"
    },
    {
      "field": "screens_or_sections",
      "question": "需要几屏或哪些模块？如果不确定，我可以先给一个最小流程。"
    },
    {
      "field": "interaction_points",
      "question": "哪些位置需要可点击、筛选、输入、展开或跳转？"
    }
  ],
  "defaults": {
    "platform": "responsive web",
    "density": "medium",
    "recommended_skill": "wireframe-sketch",
    "recommended_design_system_candidates": ["default", "figma", "notion"],
    "output_contract": "standalone low-fidelity HTML wireframe"
  }
}
